# .gitignore for netentive-deploy

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Temporary files
*.tmp
*.log

# Patched compose files (generated by deploy script)
*.patched

# Local test artifacts
test-output/

# Key server local data and env
key-server/data/
key-server/.env
key-server/__pycache__/