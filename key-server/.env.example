# Netentive Key Server — Environment Configuration
# Copy this file to .env and fill in the values.

# Per-repo SSH ED25519 private keys (base64-encoded).
# GitHub requires unique SSH keys per repo, so generate one keypair per repo.
# Generate with:
#   ssh-keygen -t ed25519 -f deploy_key_saas -N "" -C "netentive-deploy-saas"
#   ssh-keygen -t ed25519 -f deploy_key_mcp  -N "" -C "netentive-deploy-mcp"
#   ssh-keygen -t ed25519 -f deploy_key_core -N "" -C "netentive-deploy-core"
#   base64 -w0 deploy_key_saas > deploy_key_saas.b64
#   base64 -w0 deploy_key_mcp  > deploy_key_mcp.b64
#   base64 -w0 deploy_key_core > deploy_key_core.b64
# Then add each .pub file as a read-only Deploy Key to the corresponding repo:
#   netentive-saas: https://github.com/danmcrae-dev/netentive-saas/settings/keys
#   netentive-mcp:  https://github.com/danmcrae-dev/netentive-mcp/settings/keys
#   netentive-core: https://github.com/danmcrae-dev/netentive-core/settings/keys
DEPLOY_KEY_SAAS_BASE64=
DEPLOY_KEY_MCP_BASE64=
DEPLOY_KEY_CORE_BASE64=

# Legacy single key (if set, used as fallback for all repos when per-repo keys are not set)
# DEPLOY_SSH_KEY_BASE64=

# Public keys (for reference — not used by the server, just for documentation)
# Add each as a "Deploy Key" (read-only) in the corresponding GitHub repo settings.

# Server bind host and port.
KEY_SERVER_HOST=0.0.0.0
KEY_SERVER_PORT=7443

# SQLite database path (persisted via Docker volume).
DB_PATH=/data/keys.db

# Rate limit: maximum validation attempts per IP per hour.
RATE_LIMIT_PER_HOUR=5

# Comma-separated list of trusted reverse proxy IPs.
# Only these IPs' X-Forwarded-For header will be trusted for client IP detection.
# If empty (default), X-Forwarded-For is ignored and the direct connection IP is used.
# Example: TRUSTED_PROXIES=127.0.0.1,192.168.12.132
TRUSTED_PROXIES=