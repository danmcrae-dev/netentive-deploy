# Netentive Key Server — Environment Configuration
# Copy this file to .env and fill in the values.

# Base64-encoded SSH ED25519 private key used to clone the private repos.
# Generate with:
#   ssh-keygen -t ed25519 -f deploy_key -N "" -C "netentive-deploy-key"
#   base64 -w0 deploy_key > deploy_key.b64
# Then paste the contents of deploy_key.b64 here.
DEPLOY_SSH_KEY_BASE64=

# The public key string (contents of deploy_key.pub).
# Add this as a "Deploy Key" (read-only) in each GitHub repo:
#   https://github.com/danmcrae-dev/netentive-saas/settings/keys
#   https://github.com/danmcrae-dev/netentive-mcp/settings/keys
#   https://github.com/danmcrae-dev/netentive-core/settings/keys
DEPLOY_SSH_KEY_PUBLIC=

# Server bind host and port.
KEY_SERVER_HOST=0.0.0.0
KEY_SERVER_PORT=7443

# SQLite database path (persisted via Docker volume).
DB_PATH=/data/keys.db

# Rate limit: maximum validation attempts per IP per hour.
RATE_LIMIT_PER_HOUR=5

# Comma-separated list of trusted reverse proxy IPs.
# Only these IPs' X-Forwarded-For header will be trusted for client IP detection.
# If empty (default), X-Forwarded-For is ignored and the direct connection IP is used.
# Example: TRUSTED_PROXIES=127.0.0.1,192.168.12.132
TRUSTED_PROXIES=